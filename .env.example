# ─────────────────────────────────────────────────────────────
#  냉부해 네이버 블로그 자동 발행 v3 — 환경변수 설정파일
#  이 파일을 .env 로 저장하고 값을 채워넣으세요.
#  ※ 이 파일(.env)은 절대 Git 에 올리지 마세요!
# ─────────────────────────────────────────────────────────────

# [네이버 블로그]
# 블로그 URL 의 영문 ID
# 예: https://blog.naver.com/mycookblog → mycookblog
NAVER_BLOG_ID=your_naver_blog_id

# 네이버 로그인 쿠키 전체 문자열 (반드시 큰따옴표로 감쌀 것)
# 추출: 크롬 F12 → Network → 임의 요청 → Request Headers → Cookie 전체 복사
NAVER_COOKIE="NID_AUT=xxxx; NID_SES=xxxx; JSESSIONID=xxxx; NNB=xxxx; ..."

# [imgBB]
# 발급: https://api.imgbb.com → Get API key
IMGBB_API_KEY=your_imgbb_api_key

# [OpenAI]
GEMINI_API_KEY=여기에_Gemini_키_입력

# [CSV]
CSV_PATH=recipes.csv
